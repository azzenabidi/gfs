# Rows seeded into the SOURCE database (the clone copies nothing up front).
SEED_ROWS=500000

# Host ports.
SOURCE_PORT=55442   # source PostgreSQL
CLONE_PORT=55443    # GFS clone engine
SERVER_PORT=8787    # the web app

# How the clone container reaches the source (Docker Desktop on macOS/Windows).
REMOTE_HOST=host.docker.internal
